# Base URL for the Klipo API. Leave empty to call the API same-origin via the
# nginx reverse proxy in production (e.g. /api/v1/shorten). For local dev against
# the Fastify app started with `npm run dev` (port 3000), point at it directly:
NEXT_PUBLIC_API_BASE=http://localhost:3000

# Public short-link domain shown in UI copy (no scheme).
NEXT_PUBLIC_SHORT_DOMAIN=klipo.to
