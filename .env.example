# --- Database ---
# NOTE: the password embedded here must match POSTGRES_PASSWORD below.
DATABASE_URL=postgres://klip:CHANGE_ME@postgres:5432/klip
POSTGRES_PASSWORD=CHANGE_ME

# --- Redis ---
# Single-node URL — used for local dev / when REDIS_SENTINELS is unset. The
# docker-compose stack runs Redis HA via Sentinel (see REDIS_SENTINELS below) and
# ignores this. The host is the MASTER service name.
REDIS_URL=redis://redis-master:6379
REDIS_URL_TTL=86400
# Redis Sentinel HA: comma-separated host:port list. SET → connect via Sentinel
# (follows failover); UNSET → single-node REDIS_URL above. docker-compose.yml sets
# this for the dockerized app. See docs/ha-redis-sentinel.md.
# REDIS_SENTINELS=redis-sentinel-1:26379,redis-sentinel-2:26379,redis-sentinel-3:26379
# REDIS_MASTER_NAME=klip-master

# --- Short link / ID generation ---
# postgres = IDs from a Postgres SEQUENCE (durable, HA, no async-replication
# window — the default for the HA stack). redis = the Sentinel Redis INCR counter.
# snowflake = local time-based ids, NO central counter (each node mints its own) —
# requires a UNIQUE MACHINE_ID per replica; codes are 5-7 chars (vs 4-5).
COUNTER_BACKEND=postgres
# Snowflake node id, ONLY used when COUNTER_BACKEND=snowflake. Must be UNIQUE per
# app replica (0-1023). `docker compose --scale` shares this env, so set it per
# replica (e.g. separate compose entries / orchestrator ordinals) — two replicas
# with the same MACHINE_ID will mint DUPLICATE ids.
MACHINE_ID=0
# MUST be 0. The 4-char code floor comes from Hashids min-length, not the offset;
# a non-zero offset only inflates codes and is double-applied by the redis backend.
COUNTER_OFFSET=0
HASHIDS_SALT=CHANGE_ME_USE_A_LONG_RANDOM_STRING
SHORT_DOMAIN=klipo.to

# --- URL safety ---
# Optional: enable Google Safe Browsing checks on destination URLs at shorten
# time. Leave empty/unset to disable. The check is cached (12h) and fail-open.
SAFE_BROWSING_API_KEY=

# --- Email (magic-link login delivery via SMTP) ---
# When SMTP_HOST + EMAIL_FROM are set, sign-in emails are actually sent.
#   Dev:  the bundled Mailpit container captures them — SMTP_HOST=mailpit,
#         SMTP_PORT=1025, no auth; read them at http://localhost:8025.
#   Prod: point at a real SMTP relay/provider; set SMTP_USER/SMTP_PASS, and
#         SMTP_SECURE=true for implicit TLS (port 465).
# Leave SMTP_HOST empty to disable email: in development the magic link is returned
# in the API response; in production the request says "Check your email" but logs a
# warning and sends nothing.
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=
EMAIL_FROM=Klipo <login@klipo.to>

# Dashboard URL the emailed magic link points at: `${APP_BASE_URL}/?token=...`.
# The dashboard reads ?token= on load, verifies it (sets the session cookie) and
# shows the signed-in app. Dev dashboard runs on :4100 (vite --port 4100); prod =
# your real dashboard URL. Unset = the link falls back to the API verify endpoint.
APP_BASE_URL=http://localhost:4100

# How long an emailed sign-in link stays valid ("15m", "1h", "24h", "7d"). Shorter
# is safer if a link leaks; 15m is the default. (Separate from the 30d session.)
MAGIC_LINK_TTL=15m

# Secret for signing magic-link + session JWTs (>= 16 chars). Use a long random value.
SESSION_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_SECRET

# --- Quotas ---
# Active-link caps (not disabled, not expired). Over the cap → HTTP 429.
# USER_LINK_QUOTA: per signed-in user. ANON_LINK_QUOTA: per anonymous IP prefix.
USER_LINK_QUOTA=1000
ANON_LINK_QUOTA=100

# --- Retention ---
RAW_CLICK_RETENTION_DAYS=90
LINK_RETENTION_MONTHS=120

# --- Runtime ---
NODE_ENV=production
PORT=3000

# Trust the reverse proxy's client-IP headers (X-Real-IP / X-Forwarded-For).
# The bundled docker-compose runs the app behind nginx, so this MUST be true
# there (the default) — otherwise every client collapses to nginx's IP and shares
# one rate-limit bucket. Set to "false" ONLY if you expose the app directly with
# no proxy in front (e.g. local `npm run dev`), so client IPs can't be spoofed.
TRUST_PROXY=true
