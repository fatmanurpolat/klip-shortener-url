{
  "name": "klipo-app",
  "version": "0.1.0",
  "private": true,
  "description": "Klipo — self-hostable URL shortener with webview escaping",
  "license": "MIT",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "geoip-lite": "^2.0.3",
    "hashids": "^2.3.0",
    "ioredis": "^5.4.1",
    "ipaddr.js": "^2.4.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.13.1",
    "ua-parser-js": "^2.0.10",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/geoip-lite": "^1.4.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.16.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
